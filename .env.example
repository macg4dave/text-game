# Windows launcher:
# npm run dev:windows
# LiteLLM is the default AI control plane for this repo.
# Keep the app pointed at the stable gateway aliases below.
# If you want to change providers later, change `litellm.config.yaml`, not these alias names.
# Preferred cross-platform dev path:
# docker compose up --build
# If the app runs in Docker and your AI service runs on the host machine, use host.docker.internal instead of localhost.

# Choose a small end-user setup profile first, then add explicit env overrides only
# when you intentionally want advanced behavior.
# Supported values:
# - local-gpu-small
# - local-gpu-large
# - custom
AI_PROFILE=local-gpu-small

AI_PROVIDER=litellm
# Host-side LiteLLM URL for direct `npm run dev` use or manual proxy checks.
# The Docker path uses the internal Compose service URL automatically.
LITELLM_PROXY_URL=http://127.0.0.1:4000
LITELLM_API_KEY=anything
LITELLM_CHAT_MODEL=game-chat
LITELLM_EMBEDDING_MODEL=game-embedding

# Optional Compose-side overrides for Docker users.
# Keep these commented unless you intentionally need to override the built-in defaults.
# COMPOSE_AI_PROVIDER=litellm
# COMPOSE_LITELLM_PROXY_URL=http://litellm:4000
# COMPOSE_OLLAMA_BASE_URL=http://ollama:11434/v1
# LITELLM_OLLAMA_BASE_URL=http://ollama:11434
# LITELLM_IMAGE=docker.litellm.ai/berriai/litellm:main-stable
# LITELLM_PORT=4000

# Proxy-side env vars for the included `litellm.config.yaml` template.
# These are used when you start LiteLLM itself; the app does not read them.
# The current Docker smoke default starts an `ollama` service inside Compose.
# LiteLLM reaches it at http://ollama:11434 inside the Compose network.
# OPENAI_API_KEY=your_hosted_provider_key
LITELLM_MASTER_KEY=anything
# Keep LITELLM_MASTER_KEY equal to LITELLM_API_KEY for the default Docker path.
# LITELLM_OLLAMA_BASE_URL=http://ollama:11434

# Default guidance:
# - the default Docker smoke path now routes `game-chat` and `game-embedding`
#   through the repo-managed Docker Ollama service behind LiteLLM
# - `scripts/start-dev.ps1` now always starts the GPU-backed Docker path and
#   expects NVIDIA support to be available on the host
# - the local GPU tier matrix now lives in `scripts/local-gpu-profile-matrix.json`
#   for manual larger-model tuning and future automation work
# - for the default GPU-backed launcher path, use:
#   powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1
# - for a Windows Ollama example, see setup_local_a.i.md

# Optional direct OpenAI-compatible mode (not the default path):
# AI_PROVIDER=openai-compatible
# AI_API_KEY=your_key_here
# AI_BASE_URL=
# AI_CHAT_MODEL=gpt-4o-mini
# AI_EMBEDDING_MODEL=text-embedding-3-small

# Optional direct larger local-model path via Ollama.
# Prefer the LiteLLM path above when you want the same app-facing contract.
# Set AI_PROFILE=custom so startup diagnostics treat this as an intentional
# advanced override instead of a local GPU profile mismatch.
# Use http://127.0.0.1:11434/v1 for direct host `npm run dev`.
# If the app runs in Docker against host Ollama, use
# http://host.docker.internal:11434/v1 instead.
# AI_PROFILE=custom
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_API_KEY=ollama
# OLLAMA_CHAT_MODEL=gemma3:4b
# OLLAMA_EMBEDDING_MODEL=embeddinggemma

# Transitional legacy names still work during migration, but prefer the LiteLLM
# or explicit AI_PROVIDER paths above for new setup:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# OPENAI_EMBEDDING_MODEL=
# Default local app port. The Windows launcher can fall back to a nearby free
# port for a single run if this one is already busy.
PORT=3000
