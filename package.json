{
  "name": "text-game",
  "version": "0.1.0",
  "private": true,
  "description": "Windows-first text adventure prototype with a local server and desktop wrapper.",
  "author": "GitHub Copilot prototype scaffold",
  "type": "module",
  "main": "packaging/electron/main.cjs",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "sunray": "cargo run --manifest-path launcher/Cargo.toml --",
    "sunray:check": "cargo check --manifest-path launcher/Cargo.toml",
    "sunray:test": "cargo test --manifest-path launcher/Cargo.toml",
    "sunray:build-release": "cargo build --release --target-dir launcher/target --manifest-path launcher/Cargo.toml",
    "sunray:start-dev": "cargo run --manifest-path launcher/Cargo.toml -- start-dev",
    "sunray:test-local-ai-workflow": "cargo run --manifest-path launcher/Cargo.toml -- test-local-ai-workflow",
    "sunray:test-setup-browser-smoke": "cargo run --manifest-path launcher/Cargo.toml -- test-setup-browser-smoke",
    "sunray:validate-local-gpu-profile-matrix": "cargo run --manifest-path launcher/Cargo.toml -- validate-local-gpu-profile-matrix",
    "sunray:validate-litellm-default-config": "cargo run --manifest-path launcher/Cargo.toml -- validate-litellm-default-config",
    "sunray:start-desktop-prototype": "cargo run --manifest-path launcher/Cargo.toml -- start-desktop-prototype",
    "dev:windows": "cargo run --manifest-path launcher/Cargo.toml -- start-dev",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "esbuild src/ui/app.ts --bundle --format=iife --platform=browser --outfile=public/app.js",
    "build": "npm run build:server && npm run build:client",
    "type-check": "tsc -p tsconfig.json",
    "test:config": "npm run type-check && tsx --test src/core/config.test.ts",
    "test:local-ai": "npm run type-check && cargo run --manifest-path launcher/Cargo.toml -- test-local-ai-workflow",
    "test": "npm run type-check && tsx --test src/**/*.test.ts",
    "db:migrate": "npm run build:server && node dist/core/db.js migrate",
    "db:reset": "npm run build:server && node dist/core/db.js reset",
    "dev": "npm run build:client && tsx src/server/index.ts",
    "start": "node dist/server/index.js",
    "desktop:prototype:dev": "npm run build && electron .",
    "desktop:prototype:dir": "npm run build && electron-builder --dir --config packaging/electron-builder.json",
    "desktop:prototype:win": "npm run build && electron-builder --config packaging/electron-builder.json --win portable"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.27.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^25.5.0",
    "electron": "^41.0.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
